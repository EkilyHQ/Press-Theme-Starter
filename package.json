{
  "name": "@ekilyhq/press-theme-starter-development",
  "private": true,
  "engines": {
    "node": ">=22.18.0 <23"
  },
  "packageManager": "npm@10.9.3",
  "scripts": {
    "lint": "eslint . --max-warnings 0",
    "lint:debt-policy": "node scripts/test-eslint-debt-policy.mjs",
    "lint:debt-probe": "node scripts/probe-eslint-debt.mjs",
    "lint:policy": "node scripts/test-eslint-policy.mjs",
    "format:check": "node scripts/check-format.mjs",
    "security:html-sinks": "node scripts/test-html-sink-policy.mjs && node scripts/check-html-sink-policy.mjs",
    "quality": "node scripts/test-code-quality-config.mjs && npm run lint:policy && npm run lint && npm run lint:debt-policy && npm run lint:debt-probe && npm run format:check && npm run security:html-sinks"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "eslint": "10.6.0",
    "globals": "17.7.0",
    "prettier": "3.9.4"
  }
}
